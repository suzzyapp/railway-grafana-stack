{
  "uid": "infrastructure-overview",
  "title": "Infrastructure Overview",
  "tags": ["infrastructure", "nodejs", "runtime"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "type": "row",
      "title": "Prometheus Targets",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "title": "Scrape Targets Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "datasource": { "uid": "grafana_prometheus" },
      "targets": [{ "expr": "up", "legendFormat": "{{job}}" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "title": "Scrape Duration",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 1 },
      "datasource": { "uid": "grafana_prometheus" },
      "targets": [{ "expr": "scrape_duration_seconds{job=\"nestjs-olympia\"}", "legendFormat": "NestJS scrape" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "type": "row",
      "title": "Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 }
    },
    {
      "title": "RSS Memory",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "uid": "grafana_prometheus" },
      "targets": [{ "expr": "process_resident_memory_bytes", "legendFormat": "RSS" }],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 268435456 }, { "color": "red", "value": 536870912 }] }
        }
      },
      "options": { "colorMode": "background" }
    },
    {
      "title": "Heap Used vs Total",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 },
      "datasource": { "uid": "grafana_prometheus" },
      "targets": [
        { "expr": "nodejs_heap_size_used_bytes", "legendFormat": "Heap Used" },
        { "expr": "nodejs_heap_size_total_bytes", "legendFormat": "Heap Total" },
        { "expr": "process_resident_memory_bytes", "legendFormat": "RSS" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "title": "Heap Spaces",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "uid": "grafana_prometheus" },
      "targets": [{ "expr": "nodejs_heap_space_size_used_bytes", "legendFormat": "{{space}}" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 5, "stacking": { "mode": "normal" } } } }
    },
    {
      "title": "GC Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "uid": "grafana_prometheus" },
      "targets": [{ "expr": "rate(nodejs_gc_duration_seconds_sum[5m])", "legendFormat": "{{kind}}" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "type": "row",
      "title": "Event Loop & CPU",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }
    },
    {
      "title": "Event Loop Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "datasource": { "uid": "grafana_prometheus" },
      "targets": [{ "expr": "nodejs_eventloop_lag_seconds", "legendFormat": "Lag" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 15 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.1 }] }
        }
      }
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "datasource": { "uid": "grafana_prometheus" },
      "targets": [
        { "expr": "rate(process_cpu_user_seconds_total[5m])", "legendFormat": "User" },
        { "expr": "rate(process_cpu_system_seconds_total[5m])", "legendFormat": "System" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    },
    {
      "title": "Active Handles & Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 33 },
      "datasource": { "uid": "grafana_prometheus" },
      "targets": [
        { "expr": "nodejs_active_handles_total", "legendFormat": "Active Handles" },
        { "expr": "nodejs_active_requests_total", "legendFormat": "Active Requests" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    }
  ]
}
